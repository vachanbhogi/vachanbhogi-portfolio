---
import { ArrowUpRight } from "lucide-astro";
---

<section
  id="contact"
  class="section-container border-t border-[#e5e5e5] scroll-mt-24"
>
  <div class="grid md:grid-cols-[1fr_2fr] gap-8 md:gap-16">
    <div>
      <h2
        class="font-mono text-xs font-bold uppercase tracking-widest text-[#666666]"
      >
        vachan.contact()
      </h2>
    </div>

    <div class="space-y-8">
      <div class="space-y-4">
        <p class="text-[#111111] text-sm font-medium">
          Please email me to request a full resume.
        </p>
      </div>

      <div
        class="flex flex-col sm:flex-row gap-6 sm:gap-12 pt-4 border-t border-[#e5e5e5]"
      >
        <a
          href="mailto:vachanbhogi@gmail.com"
          class="group flex items-center gap-1.5 text-sm font-medium text-[#111111] hover:text-[#666666] transition-colors"
          aria-label="Send email to vachanbhogi@gmail.com"
        >
          Email <ArrowUpRight
            size={14}
            class="opacity-50 group-hover:opacity-100 transition-opacity"
          />
        </a>
        <a
          href="https://linkedin.com/in/vachanbhogi"
          target="_blank"
          class="group flex items-center gap-1.5 text-sm font-medium text-[#111111] hover:text-[#666666] transition-colors"
          aria-label="Visit Vachan Bhogi's LinkedIn profile"
        >
          LinkedIn <ArrowUpRight
            size={14}
            class="opacity-50 group-hover:opacity-100 transition-opacity"
          />
        </a>
        <a
          href="https://github.com/vachanbhogi"
          target="_blank"
          class="group flex items-center gap-1.5 text-sm font-medium text-[#111111] hover:text-[#666666] transition-colors"
          aria-label="Visit Vachan Bhogi's GitHub profile"
        >
          GitHub <ArrowUpRight
            size={14}
            class="opacity-50 group-hover:opacity-100 transition-opacity"
          />
        </a>
      </div>
    </div>
  </div>
</section>
