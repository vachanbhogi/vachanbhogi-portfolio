---
import { ExternalLink } from "lucide-astro";

const projects = [
  {
    title: "Semper Systems",
    role: "Co-Founder",
    period: "April 2025 – Present",
    description:
      "Developed an on-device multimodal agent running Gemma 4 locally on Apple Silicon. Optimized hardware performance and built context-aware infrastructure to enable privacy-first agentic workflows.",
    tags: ["Apple MLX", "Gemma 4", "SwiftUI", "Python", "Local LLMs"],
    link: "https://www.semper.systems/",
  },
  {
    title: "Marks for Infinite Campus",
    role: "Co-Founder",
    period: "January 2025 – Present",
    description:
      "Engineered a high-performance mobile application for grade tracking and academic utility. Built a custom API layer to aggregate data from legacy educational systems for over 2,000 active users.",
    tags: ["Mobile Development", "API Architecture", "Next.js", "System Design"],
    link: "https://www.marks.cx/",
  },
];
---

<section id="projects" class="section-container border-t border-[#e5e5e5] scroll-mt-24">
  <div class="grid md:grid-cols-[1fr_2fr] gap-8 md:gap-16">
    <div>
      <h2
        class="font-mono text-xs font-bold uppercase tracking-widest text-[#666666]"
      >
        vachan.work()
      </h2>
    </div>

    <div class="space-y-12">
      {
        projects.map((project) => (
          <article class="group">
            <header class="mb-4">
              <div class="flex justify-between items-baseline mb-1">
                <h3 class="text-lg font-medium text-[#111111] flex items-center gap-2">
                  {project.title}
                  <a
                    href={project.link}
                    target="_blank"
                    class="text-[#666666] hover:text-[#111111] transition-colors"
                    aria-label={`Visit ${project.title} website`}
                  >
                    <ExternalLink size={14} />
                  </a>
                </h3>
                <span class="text-xs text-[#666666] font-medium tracking-wide">
                  {project.period}
                </span>
              </div>
              <p class="text-sm font-medium text-[#666666]">{project.role}</p>
            </header>

            <p class="text-[#444444] text-base leading-relaxed mb-6">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-[11px] font-mono text-[#666666] border border-[#e5e5e5] px-2 py-1 bg-[#f4f1ea]">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
