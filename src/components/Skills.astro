---
const skillGroups = [
  {
    title: "AI / Machine Learning",
    skills: ["PyTorch", "Apple MLX", "Transformers", "Local Inference", "Model Quantization"],
  },
  {
    title: "Web & Mobile Development",
    skills: ["Next.js", "Astro", "Tailwind CSS", "TypeScript", "Swift / SwiftUI", "API Design"],
  },
  {
    title: "Game Design & Graphics",
    skills: ["Godot Engine", "GDScript", "C#", "Metal", "Shader Programming"],
  },
  {
    title: "Engineering Fundamentals",
    skills: ["Python", "C++", "Java", "Linux", "Git", "SQLite"],
  },
];
---

<section id="skills" class="section-container border-t border-[#e5e5e5] scroll-mt-24">
  <div class="grid md:grid-cols-[1fr_2fr] gap-8 md:gap-16">
    <div>
      <h2 class="font-mono text-xs font-bold uppercase tracking-widest text-[#666666]">vachan.stack()</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-x-12 gap-y-10">
      {
        skillGroups.map((group) => (
          <div>
            <h3 class="text-sm font-semibold text-[#111111] mb-4 pb-2 border-b border-[#e5e5e5]">
              {group.title}
            </h3>
            <ul class="space-y-2">
              {group.skills.map((skill) => (
                <li class="text-sm text-[#444444]">{skill}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
